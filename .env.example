POSTGRES_PASSWORD=changeme
# Strava is optional for FIT-only usage.
# Leave these empty to run VeloMate with manual FIT uploads only.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
GRAFANA_PASSWORD=changeme

# Fitness thresholds (optional — auto-estimated from data if not set)
VELOMATE_MAX_HR=0         # Your max heart rate (e.g. 182)
VELOMATE_FTP=0            # Your FTP in watts (e.g. 165)
VELOMATE_RESTING_HR=0     # Your resting heart rate (e.g. 48). Default: 50 bpm
VELOMATE_WEIGHT=0         # Your weight in kg (e.g. 75). Enables W/kg on Activity Details

# Backfill window — how far back to pull activities from Strava.
# 12  = last 12 months (default — first sync completes in ~15 min for typical amateur)
# 24  = last 2 years
# 0   = full history (slow — may take hours and span multiple days due to Strava rate limits)
# Increasing this value on a running deployment auto-triggers a re-backfill on the
# next restart so the extended window actually pulls older activities. Decreasing it
# leaves existing older data in the DB (this controls the backfill horizon, not retention).
VELOMATE_BACKFILL_MONTHS=12

# FIT upload web UI
WEB_PORT=8080
